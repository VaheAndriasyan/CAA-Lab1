import platform
import uuid
import shutil
import hashlib
import os


info = {
    "cpu": platform.processor().strip(),
    "mac": ":".join(f"{uuid.getnode():012x}[i:i+2]" for i in range(0, 12, 2)),
    "disk": str(shutil.disk_usage("C:\\" if os.name == "nt" else "/").total)
}

raw = "".join(info.values())

print("Raw info:", raw)

fingerprint = hashlib.sha256(raw.encode("utf-8")).hexdigest()

print("System fingerprint:", fingerprint)
